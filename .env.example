# ─────────────────────────────────────────────
# Nucleus Chatbot Backend — Environment Config
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nucleus-chatbot?retryWrites=true&w=majority

# Google AI (Gemini 1.5 Flash)
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
GEMINI_CHAT_MODEL=gemini-1.5-flash-latest
GEMINI_CHAT_API_VERSION=v1beta
GEMINI_TRANSCRIBE_MODEL=gemini-1.5-flash-latest
GEMINI_TRANSCRIBE_FALLBACK_MODEL=gemini-1.5-flash-latest
GEMINI_TRANSCRIBE_API_VERSION=v1beta
GEMINI_API_VERSION=v1
# GEMINI_API_BASE_URL=

# Performance tuning
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_RAG_TOP_K=2

# Gemini 2.0 Flash Multimodal Live API (voice-to-voice WebSocket)
# List models: GET https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_KEY
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
ENABLE_TTS=true
TTS_TIMEOUT_MS=3500

# OpenAI (Whisper STT + TTS)
OPENAI_API_KEY=your_openai_api_key_here

# PDF Paths (comma/semicolon-separated, relative to backend root)
PDF_PATHS=./data/Nucleus_Distribution_Pvt._Ltd._Profile_2025.pdf,./data/Mushaba Rag.pdf
